  "keyFeatures": [
    "JWT-based authentication with buyer, seller, and admin roles",
    "Marketplace listings with category, price, and condition filters",
    "Real-time buyer-seller chat powered by Firebase Firestore",
    "AI-powered chatbot assistant using Google Gemini for natural language search",
    "Image upload and management via AWS S3 / MinIO with presigned URLs",
    "Admin dashboard with user management, report handling, and platform analytics",
    "WebSocket server with pub/sub architecture for real-time notifications",
    "Microservices backend: API server, WebSocket server, and background worker"
  ],
